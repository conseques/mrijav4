rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/volunteers/$(request.auth.uid)).data.role;
    }

    function getUserStatus() {
      return get(/databases/$(database)/documents/volunteers/$(request.auth.uid)).data.status;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isManager() {
      return isAuthenticated() && (getUserRole() == 'manager' || getUserRole() == 'admin');
    }

    function isApprovedVolunteer() {
      return isAuthenticated() && getUserStatus() == 'approved';
    }

    // Volunteers Collection
    match /volunteers/{userId} {
      // Anyone authenticated can read their own profile, managers can read all
      allow read: if isOwner(userId) || isManager();
      
      // Users can create their own profile, but cannot assign themselves as 'admin' or 'manager'
      allow create: if isOwner(userId) 
                    && request.resource.data.role == 'user'
                    && request.resource.data.status == 'pending';
                    
      // Users can update their own profile (e.g. skills), but cannot change their role or approval status
      allow update: if (isOwner(userId) 
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['skills', 'phone', 'name'])) // Limit what they can edit
                    || isManager(); // Managers can update status and roles

      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    // Volunteer Tasks Collection
    match /volunteerTasks/{taskId} {
      // Approved volunteers can view tasks
      allow read: if isApprovedVolunteer() || isManager();

      // Managers/admins can create or remove tasks
      allow create, delete: if isManager();

      // Managers/admins can fully edit tasks
      // Approved volunteers can only add themselves to appliedUsers
      allow update: if isManager()
                    || (
                      isApprovedVolunteer()
                      && request.resource.data.appliedUsers is list
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['appliedUsers'])
                      && (
                        (
                          resource.data.appliedUsers is list
                          && request.resource.data.appliedUsers.size() == resource.data.appliedUsers.size() + 1
                          && request.resource.data.appliedUsers.hasAll(resource.data.appliedUsers)
                        )
                        || (
                          !(resource.data.appliedUsers is list)
                          && request.resource.data.appliedUsers.size() == 1
                        )
                      )
                      && request.resource.data.appliedUsers.hasAll([request.auth.uid])
                    );
    }

    // Events Collection (Public Read, Manager Write)
    match /events/{eventId} {
      allow read: if true;
      allow write: if isManager();
    }

    // Courses Collection (Public Read, Manager Write)
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isManager();
    }

    // Reports Collection (Public Read — transparency report shown to all visitors)
    match /reports/{reportId} {
      allow read: if true;
      allow write: if isManager();
    }

    // Registrations Collection
    match /registrations/{registrationId} {
      allow create: if request.resource.data.keys().hasOnly([
                        'name',
                        'email',
                        'phone',
                        'eventName',
                        'type',
                        'source',
                        'paymentReference',
                        'paymentState',
                        'createdAt'
                      ])
                    && request.resource.data.keys().hasAll([
                        'name',
                        'email',
                        'eventName',
                        'createdAt'
                      ])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 120
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() <= 160
                    && request.resource.data.eventName is string
                    && request.resource.data.eventName.size() > 0
                    && request.resource.data.eventName.size() <= 160
                    && request.resource.data.createdAt is timestamp
                    && (!('phone' in request.resource.data) || request.resource.data.phone is string)
                    && (!('type' in request.resource.data) || request.resource.data.type in ['event', 'membership'])
                    && (!('source' in request.resource.data) || request.resource.data.source is string)
                    && (!('paymentReference' in request.resource.data) || request.resource.data.paymentReference is string)
                    && (!('paymentState' in request.resource.data) || request.resource.data.paymentState is string);

      allow read, update, delete: if isManager();
    }

    // Memberships Collection
    match /memberships/{membershipId} {
      allow read, create, update, delete: if isManager();
    }

    // Past Events Collection (Public Read, Manager Write)
    match /past_events/{eventId} {
      allow read: if true;
      allow write: if isManager();
    }
  }
}
